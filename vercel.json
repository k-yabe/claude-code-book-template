{
  "github": { "silent": true },
  "functions": {
    "api/generate.js": { "maxDuration": 60 },
    "api/slide-ops.js": { "maxDuration": 60 },
    "api/slide-export.py": { "maxDuration": 60 },
    "api/slide-research.js": { "maxDuration": 120 },
    "api/fetch-article.js": { "maxDuration": 30 },
    "api/sources.js": { "maxDuration": 10 },
    "api/fetch-transcript.js": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api/proxy", "destination": "/api/fetch-article?mode=proxy" },
    { "source": "/api/ogp", "destination": "/api/fetch-article?mode=ogp" },
    { "source": "/api/slide-factcheck", "destination": "/api/slide-ops?action=factcheck" },
    { "source": "/api/slide-generate", "destination": "/api/slide-ops?action=generate" },
    { "source": "/api/slide-image", "destination": "/api/slide-ops?action=image" }
  ],
  "headers": [
    {
      "source": "/api/proxy",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors 'self'" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
